  "architecture": {
    "decisions": [
      { "id": "a1", "title": "Tauri over Electron", "rationale": "Smaller bundle size (~10MB vs ~150MB), better performance, Rust backend for safety", "date": "2026-03-01", "status": "accepted" },
      { "id": "a2", "title": "Trunk-based development", "rationale": "Short-lived branches, always-deployable main, reduces merge conflicts", "date": "2026-03-01", "status": "accepted" },
      { "id": "a3", "title": "SQLite via sqlx", "rationale": "Embedded DB, no server required, async support, compile-time query checking", "date": "2026-03-07", "status": "proposed" },
      { "id": "a4", "title": "AppError unified enum", "rationale": "Single error type with thiserror, serializable for frontend, no unwrap() in production", "date": "2026-03-07", "status": "accepted" }
    ],
    "patterns": [
      { "name": "Commands as thin wrappers", "description": "Tauri commands only validate input and delegate to services. No business logic in commands." },
      { "name": "Services layer", "description": "All business logic in src-tauri/src/services/. No Tauri imports. Fully testable." },
      { "name": "Conventional Commits", "description": "feat/fix/chore/refactor/docs/build/test/perf with optional scope." }
    ]
  },
